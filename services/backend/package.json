{
  "name": "backend",
  "version": "1.0.0",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "wrangler dev src/index.ts --port 3000",
    "build": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "test": "tsx --test \"src/**/*.test.ts\"",
    "deploy": "wrangler deploy",
    "db:generate": "drizzle-kit generate --config src/db/drizzle.config.ts",
    "db:push": "drizzle-kit push --config src/db/drizzle.config.ts",
    "db:seed": "tsx src/db/seed.ts",
    "db:studio": "drizzle-kit studio --config src/db/drizzle.config.ts",
    "generate:openapi": "tsx scripts/generate-openapi.ts"
  },
  "dependencies": {
    "hono": "^4.7.0",
    "@hono/zod-openapi": "^0.18.0",
    "@neondatabase/serverless": "^1.0.0",
    "zod": "^3.24.0",
    "drizzle-orm": "^0.42.0",
    "drizzle-zod": "^0.7.0",
    "pg": "^8.14.0",
    "dotenv": "^16.5.0"
  },
  "devDependencies": {
    "drizzle-kit": "^0.31.0",
    "tsx": "^4.19.0",
    "@types/pg": "^8.11.0",
    "@cloudflare/workers-types": "^4.20260529.0",
    "wrangler": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
